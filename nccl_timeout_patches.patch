## 补丁1: proxy.h - 添加超时检测数据结构

```diff
--- a/src/include/proxy.h
+++ b/src/include/proxy.h
@@ -120,6 +120,11 @@ struct ncclProxySubArgs {
   size_t transSize;
   uint64_t workCounter;
 
+  // Timeout detection fields
+  uint64_t startTime;        // Operation start time (microseconds)
+  uint64_t lastActiveTime;   // Last active time (microseconds)
+  int timeoutDetected;       // Timeout detected flag
+
   void* recvRequestsCache[NCCL_STEPS];
   int recvRequestsSubCount;
 };
@@ -154,6 +159,10 @@ struct ncclProxyArgs {
   int nChannels;
   int nPeers;
 
+  // Timeout detection fields
+  uint64_t opStartTime;      // Overall operation start time
+  int timeoutLogged;         // Timeout logged flag
+
   int idle;
 
   // Element linking
@@ -315,4 +324,36 @@ ncclResult_t ncclProxyStop(struct ncclComm* comm);
 ncclResult_t ncclProxyShmUnlink(struct ncclComm* comm);
 ncclResult_t ncclProxyDestroy(struct ncclComm* comm);
+
+// Timeout detection utility functions
+
+// Get current time in microseconds
+static inline uint64_t ncclProxyGetTimeUs() {
+  struct timespec ts;
+  clock_gettime(CLOCK_MONOTONIC, &ts);
+  return (uint64_t)ts.tv_sec * 1000000ULL + ts.tv_nsec / 1000;
+}
+
+// Timeout configuration structure
+struct ncclProxyTimeoutConfig {
+  int enabled;               // Whether timeout is enabled
+  uint64_t timeoutUs;        // Timeout in microseconds
+  int logOnly;               // Only log, don't fail
+  uint64_t checkIntervalUs;  // Check interval in microseconds
+};
+
+// Forward declaration of timeout parameter functions
+int64_t ncclParamProxyTimeoutMs();
+int64_t ncclParamProxyTimeoutLogOnly();
+int64_t ncclParamProxyTimeoutCheckInterval();
+
+// Get timeout configuration
+static inline void ncclProxyGetTimeoutConfig(struct ncclProxyTimeoutConfig* config) {
+  config->enabled = ncclParamProxyTimeoutMs() > 0;
+  config->timeoutUs = (uint64_t)ncclParamProxyTimeoutMs() * 1000;
+  config->logOnly = ncclParamProxyTimeoutLogOnly();
+  config->checkIntervalUs = (uint64_t)ncclParamProxyTimeoutCheckInterval() * 1000;
+}
+
 #endif
